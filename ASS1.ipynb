    "# BMI Calculator\n",
    "\n",
    "# Receive input from the user\n",
    "weight = float(input(\"Enter your weight in kilograms: \"))\n",
    "height = float(input(\"Enter your height in metres: \"))\n",
    "\n",
    "# Calculate BMI\n",
    "bmi = round(weight / (height ** 2), 2)\n"
